<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme -->
    <style name="Theme.FloodAlert" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSurface">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_secondary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Navigation Polish: Sleek Pill Indicator -->
    <style name="App.Custom.Indicator" parent="">
        <item name="android:height">32dp</item>
        <item name="android:width">48dp</item>
    </style>

    <!-- Navigation Text Appearance -->
    <style name="TextAppearance.App.Nav.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">11sp</item>
    </style>

</resources>
