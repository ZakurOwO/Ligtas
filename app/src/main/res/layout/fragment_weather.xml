<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_topbar_modern"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_icon_blue">

            <ImageView
                android:layout_width="19dp"
                android:layout_height="19dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_weather"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_location_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="Weather"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/btn_refresh_weather"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh Weather"
            android:padding="8dp"
            android:src="@drawable/ic_refresh"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tv_user_initial"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:text="J"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_weather"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="88dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="236dp"
                    android:background="@drawable/bg_weather_hero"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_temperature"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="29°"
                                android:textColor="@color/text_white"
                                android:textSize="52sp" />

                            <TextView
                                android:id="@+id/tv_feels_like"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="-4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Feels like 36°C"
                                android:textColor="@color/text_white"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="76dp"
                                android:layout_height="76dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_weather"
                                app:tint="@color/text_white" />

                            <TextView
                                android:id="@+id/tv_condition"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="Light Rain"
                                android:textColor="@color/text_white"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_weather_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="3dp"
                        android:text="Warm and humid with scattered thunderstorms expected throughout the day as the monsoon season begins."
                        android:textColor="@color/text_white"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_weather_advisory"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_droplet"
                            app:tint="@color/text_white" />

                        <TextView
                            android:id="@+id/tv_rain_advisory"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-black"
                            android:text="60% chance of rain — Stay alert for flood advisories"
                            android:textColor="@color/text_white"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:columnCount="2"
                    android:rowCount="2">

                    <include
                        android:id="@+id/card_humidity"
                        layout="@layout/item_weather_small"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="7dp"
                        android:layout_marginBottom="14dp" />

                    <include
                        android:id="@+id/card_wind"
                        layout="@layout/item_weather_small"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="7dp"
                        android:layout_marginBottom="14dp" />

                    <include
                        android:id="@+id/card_precipitation"
                        layout="@layout/item_weather_small"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="7dp" />

                    <include
                        android:id="@+id/card_flood_risk"
                        layout="@layout/item_weather_small"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="7dp" />
                </GridLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="sans-serif-black"
                    android:text="3-DAY FORECAST"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <include layout="@layout/item_forecast_row" android:id="@+id/forecast_friday" />
                <include layout="@layout/item_forecast_row" android:id="@+id/forecast_saturday" />
                <include layout="@layout/item_forecast_row" android:id="@+id/forecast_sunday" />

                <TextView
                    android:id="@+id/tv_last_updated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Last updated: Just now"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
