<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_secondary"
    android:orientation="vertical">

    <!-- Modern Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_topbar_modern"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="Report Icon"
            android:src="@drawable/ic_report"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="Report Flood"
            android:textColor="@color/text_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tv_user_initial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:text="U"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="100dp">

            <!-- Photo Upload Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/upload_photo_area"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_photo_preview"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:contentDescription="Upload Photo"
                        android:src="@drawable/ic_photo_upload"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Snap a Photo"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Tap to capture flood evidence"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-black"
                android:text="Incident Details"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <!-- Location Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_input_selector"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/text_tertiary" />

                <Spinner
                    android:id="@+id/spinner_barangay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:spinnerMode="dropdown" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_location_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"
                android:text="@string/detecting_location"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- Description Input -->
            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_input_selector"
                android:gravity="top|start"
                android:hint="Describe the situation (e.g. knee-deep water, impassable road)"
                android:inputType="textMultiLine"
                android:padding="20dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_submit_report"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/bg_button_primary"
                android:fontFamily="sans-serif-black"
                android:text="Send Report"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_send"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/text_white" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>