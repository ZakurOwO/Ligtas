rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    function isAdminOrOfficer() {
      return getUserRole() in ['admin', 'mdrrmo_officer'];
    }

    // Users collection
    match /users/{uid} {
      allow read: if isLoggedIn() && (isOwner(uid) || isAdminOrOfficer());
      allow create: if isLoggedIn() && isOwner(uid);
      allow update: if isLoggedIn() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    // Alerts — all logged-in users can read; only admin can write
    match /alerts/{alertId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Reports — residents create; officers/admin can update status
    match /reports/{reportId} {
      allow read: if isLoggedIn() && (
        isOwner(resource.data.submittedBy) || isAdminOrOfficer()
      );
      allow create: if isLoggedIn();
      allow update: if isAdminOrOfficer();
      allow delete: if isAdmin();
    }

    // Safety Tips — all read; admin write only
    match /safetyTips/{tipId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Go Bag Items — all read; admin write only
    match /goBagItems/{itemId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Go Bag Progress — user owns their own progress
    match /goBagProgress/{uid} {
      allow read, write: if isLoggedIn() && isOwner(uid);
    }

    // Emergency Contacts — all read; admin write only
    match /emergencyContacts/{contactId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Weather Cache — all read; Cloud Functions write only
    match /weatherCache/{city} {
      allow read: if isLoggedIn();
      allow write: if false; // written only by Cloud Functions or server
    }

    // Audit Logs - admins/officers can view; authenticated app users can append activity
    match /auditLogs/{logId} {
      allow read: if isLoggedIn() && isAdminOrOfficer();
      allow create: if isLoggedIn();
      allow update, delete: if false;
    }

    // App Config — all read; admin write only
    match /appConfig/{doc} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
